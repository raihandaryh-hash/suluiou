# =============================================================================
# Sulu — Production Environment Variables
# =============================================================================
# Salin file ini jadi `.env.production` saat build untuk deploy.
# Pilih SATU dari Opsi A atau Opsi B di bawah.
# =============================================================================

# -----------------------------------------------------------------------------
# OPSI A — Frontend di IOU, Backend tetap Lovable Cloud (REKOMENDASI)
# -----------------------------------------------------------------------------
# Biarkan VITE_API_BASE_URL kosong. Frontend akan langsung pakai Supabase
# (database, auth, edge functions AI) lewat client SDK.
# Cukup `npm run build` lalu upload `dist/` ke server IOU.
#
VITE_API_BASE_URL=

# -----------------------------------------------------------------------------
# OPSI B — Full migrasi ke backend PHP/MySQL Mas Shofiq
# -----------------------------------------------------------------------------
# Uncomment & isi dengan root URL backend PHP. Frontend akan hit endpoint REST
# di `${VITE_API_BASE_URL}/api/results`, `/api/generate-projection`, dst.
# Pastikan endpoint sudah diimplementasi sesuai docs/API_CONTRACT.md.
#
# VITE_API_BASE_URL=https://bahasa.iou.edu.gm/sulu

# =============================================================================
# Variabel di bawah HANYA dipakai untuk Opsi A (Supabase mode).
# Untuk Opsi B, variabel ini diabaikan oleh `src/services/api.ts`.
# Nilai di bawah di-inject otomatis oleh Lovable saat build di Lovable editor.
# Kalau build di mesin lokal, copy dari Lovable editor → Settings → Env.
# =============================================================================

VITE_SUPABASE_URL=https://qjdmwssuzthihtxekeup.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PROJECT_ID=qjdmwssuzthihtxekeup
